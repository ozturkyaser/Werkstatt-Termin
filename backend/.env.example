# ===== Grundlegende Konfiguration =====
PORT=4100
NODE_ENV=development
JWT_SECRET=bitte-hier-einen-sehr-langen-zufallswert-eintragen
JWT_EXPIRES_IN=7d

# Frontend URL (für CORS)
FRONTEND_URL=http://localhost:5173

# Datenbankpfad (SQLite)
DATABASE_PATH=./data/werkstatt.sqlite

# ===== Erinnerungen =====
# Wie viele Stunden vor dem Termin eine Erinnerung gesendet wird
REMINDER_HOURS_BEFORE=24

# Standard-Werkstattdaten (werden in Erinnerungen verwendet)
WORKSHOP_NAME=Fast Cars Autohaus
WORKSHOP_ADDRESS=Wittestr. 26A, 13509 Berlin-Wittenau
WORKSHOP_PHONE=030 40244 15
WORKSHOP_EMAIL=info@fastcars.de

# ===== E-Mail (SMTP, z.B. Gmail, Mailgun, eigener Server) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Fast Cars Autohaus <no-reply@fastcars.de>"

# ===== SMS (Twilio) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== WhatsApp (Twilio WhatsApp Sandbox oder Business API) =====
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Wenn leer gelassen, werden Nachrichten nur ins Log geschrieben (Dry-Run).
