# Kopie nach .env.deploy und anpassen (nicht committen – steht in .gitignore)
# Bequemer: ./deploy-wizard.sh (legt diese Datei interaktiv an)

# Pflicht
DO_HOST=123.45.67.89
DO_SSH_USER=root

# SSH: Entweder Key …
DO_SSH_KEY=${HOME}/.ssh/id_ed25519
# … oder Passwort (nicht hier eintragen – nur vom Wizard per Umgebungsvariable).
# DO_SSH_USE_PASSWORD=1

HTTP_PORT=80

# Installationsverzeichnis auf dem Droplet
DO_APP_DIR=/opt/werkstatt-termin

# --- Optional: .env.docker auf den Server schreiben (Variante A) ---
# Wenn JWT_SECRET und FRONTEND_URL gesetzt sind, wird docker/env.ci.template gefüllt und als .env.docker hochgeladen.
# JWT_SECRET=
# FRONTEND_URL=https://termin.deine-domain.de
# PUBLIC_APP_URL=
# JWT_EXPIRES_IN=7d
# WORKSHOP_NAME=
# WORKSHOP_ADDRESS=
# WORKSHOP_PHONE=
# WORKSHOP_EMAIL=
# REMINDER_HOURS_BEFORE=24
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Optional: lokale .env.docker hochladen (Variante B) ---
# DEPLOY_USE_LOCAL_ENV_DOCKER=1
