# Kopie nach .env.docker und Werte setzen (nicht committen).
# FRONTEND_URL = öffentliche URL der App (gleiche Domain wie Nginx), für CORS zwingend korrekt setzen.

NODE_ENV=production
PORT=4100
DATABASE_PATH=/app/data/werkstatt.sqlite

JWT_SECRET=bitte-mindestens-32-zeichen-zufaellig-ersetzen
JWT_EXPIRES_IN=7d

# Öffentliche Basis-URL (https://… ohne Slash am Ende) — alternativ im Einrichtungs-Wizard
FRONTEND_URL=https://ihre-domain.de

# Nur für den vollständigen Wizard-Link im Server-Log (optional, solange FRONTEND_URL noch fehlt)
PUBLIC_APP_URL=
WORKSHOP_NAME=Fast Cars Autohaus
WORKSHOP_ADDRESS=
WORKSHOP_PHONE=
WORKSHOP_EMAIL=

REMINDER_HOURS_BEFORE=24

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Werkstatt <no-reply@ihre-domain.de>"

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: KI / Telefon-KI (wie backend/.env.example)
# OPENAI_API_KEY=
# …
